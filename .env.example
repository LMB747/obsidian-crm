# ─── Obsidian Agency CRM — Variables d'environnement ──────────────────────────
# Copier ce fichier en .env.local et remplir les valeurs

# Resend (envoi d'emails)
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
VITE_RESEND_FROM=Obsidian Agency <noreply@obsidian.agency>

# Stripe (paiements)
VITE_STRIPE_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Supabase (base de données)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# RevenueCat (abonnements mobiles)
VITE_REVENUECAT_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx
VITE_REVENUECAT_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxx

# App
VITE_APP_NAME=Obsidian Agency CRM
VITE_APP_VERSION=2.0.0
