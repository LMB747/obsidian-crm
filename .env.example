# ── Obsidian Agency CRM — Variables d'environnement ──────────────────────────
# Copiez ce fichier en .env.local et renseignez vos valeurs réelles
# Ne commitez JAMAIS .env.local dans git

# ── RevenueCat (Pay to Snooze) ────────────────────────────────────────────────
# Obtenez votre clé sur https://app.revenuecat.com → Projet → API Keys
# VITE_REVENUECAT_API_KEY=your_revenuecat_secret_key_here

# ── Stripe (Pénalités Pay to Snooze) ─────────────────────────────────────────
# Obtenez vos clés sur https://dashboard.stripe.com/apikeys
# VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
# VITE_STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx  # À mettre UNIQUEMENT dans les Netlify env vars, jamais côté client

# ── Apify (Scraping IA) ───────────────────────────────────────────────────────
# Obtenez votre clé sur https://console.apify.com/account/integrations
# À renseigner dans l'interface → Prospection IA → Configuration

# ── Resend (Emails) ───────────────────────────────────────────────────────────
# Obtenez votre clé sur https://resend.com/api-keys
# À renseigner dans Paramètres → Intégrations

# ── Supabase (Optionnel — stockage cloud) ────────────────────────────────────
# Pour activer la persistance cloud au lieu de localStorage
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJxxxxxxxx
